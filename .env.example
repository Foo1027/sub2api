TZ=Asia/Shanghai

# Network
BIND_HOST=127.0.0.1
SERVER_PORT=8080

# Sub2API bootstrap
AUTO_SETUP=true
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# Postgres
POSTGRES_DB=sub2api
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=

# Redis
REDIS_PASSWORD=

# Optional upstream compatibility toggles
ALLOW_PRIVATE_HOSTS=false
ALLOW_INSECURE_HTTP=false
